<?xml version="1.0" encoding="utf-8"?>
<ESRI.Configuration xmlns="http://schemas.esri.com/Desktop/AddIns"
                    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <Name>arcmap-mcp</Name>
  <AddInID>{931c022e-51ae-4daf-84ff-c1015b130649}</AddInID>
  <Description>Levanta/para el puente MCP dentro de ArcMap (socket 127.0.0.1:27179). Permite conducir la sesion viva de ArcMap desde un agente IA (Claude, etc.). Autor: Pedro Alcoba Gomez (pedralcg.dev).</Description>
  <Version>0.14</Version>
  <Author>Pedro Alcoba Gomez — pedralcg.dev · pedro@pedralcg.dev · GitHub @pedralcg</Author>
  <Company>pedralcg.dev</Company>
  <Date>2026-06-01</Date>
  <Targets>
    <Target name="Desktop" version="10.5" />
  </Targets>
  <AddIn language="PYTHON" library="arcmap_mcp_addin.py" namespace="arcmap_mcp_addin">
    <ArcMap>
      <Commands>
        <Button id="arcmapmcp_start"
                class="arcmap_mcp_addin.ButtonStart"
                message="Arranca el puente MCP (socket 127.0.0.1:27179)."
                caption="Iniciar MCP"
                tip="Levantar el puente MCP (socket 127.0.0.1:27179)"
                image="Images/start.png"
                category="arcmap-mcp" />
        <Button id="arcmapmcp_stop"
                class="arcmap_mcp_addin.ButtonStop"
                message="Detiene el puente MCP."
                caption="Detener MCP"
                tip="Detener el puente MCP"
                image="Images/stop.png"
                category="arcmap-mcp" />
        <Button id="arcmapmcp_status"
                class="arcmap_mcp_addin.ButtonStatus"
                message="Muestra el estado del puente MCP."
                caption="Estado MCP"
                tip="Ver estado del puente (ACTIVO / PARADO) y host:puerto"
                image="Images/status.png"
                category="arcmap-mcp" />
        <Button id="arcmapmcp_about"
                class="arcmap_mcp_addin.ButtonAbout"
                message="Informacion del autor de arcmap-mcp."
                caption="Acerca de"
                tip="Ficha del autor: Pedro Alcoba Gomez - pedralcg.dev"
                image="Images/about.png"
                category="arcmap-mcp" />
      </Commands>
      <Toolbars>
        <Toolbar id="arcmapmcp_toolbar" caption="arcmap-mcp" showInitially="true">
          <Items>
            <Button refID="arcmapmcp_start" />
            <Button refID="arcmapmcp_stop" />
            <Button refID="arcmapmcp_status" />
            <Button refID="arcmapmcp_about" />
          </Items>
        </Toolbar>
      </Toolbars>
    </ArcMap>
  </AddIn>
</ESRI.Configuration>
