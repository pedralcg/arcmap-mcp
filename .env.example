# Variables de entorno de arcmap-mcp (todas OPCIONALES; hay valores por defecto).
#
# Importante: el SERVER (src/arcmap_mcp_server.py) y el PUENTE (src/arcmap_bridge.py)
# leen estas variables del ENTORNO del sistema/usuario. Este archivo es una REFERENCIA
# de las variables disponibles: defínelas como variables de usuario de Windows (antes de
# abrir ArcMap, para el puente), o en el bloque "env" de la config MCP de tu cliente
# (para el server).

# --- Server MCP (Python 3) -------------------------------------------------- #
# Host del puente. 127.0.0.1 en local; IP del equipo si ArcMap está en otra máquina.
# ARCMAP_BRIDGE_HOST=127.0.0.1
# Puerto del puente (debe coincidir con el del puente).
# ARCMAP_BRIDGE_PORT=27179
# Timeout (s) de las tools RÁPIDAS (consultas, capas, exportaciones cortas).
# ARCMAP_BRIDGE_TIMEOUT=60
# Timeout (s) de los GEOPROCESOS PESADOS (análisis ambiental, run_geoprocessing, LiDAR/TIN).
# Súbelo para rásters muy grandes; el proceso sigue vivo en ArcMap aunque el server corte.
# ARCMAP_GP_TIMEOUT=1800

# --- Puente dentro de ArcMap (Python 2.7) ----------------------------------- #
# Interfaz de escucha. 127.0.0.1 = solo local; 0.0.0.0 = aceptar red (Tailscale/VPN).
# ARCMAP_BRIDGE_BIND=127.0.0.1

# --- Add-In (barra de botones) ---------------------------------------------- #
# Carpeta del repo si NO está en C:\mcp\arcmap-mcp (default). Define antes de abrir ArcMap.
# ARCMAP_MCP_DIR=C:\mcp\arcmap-mcp
