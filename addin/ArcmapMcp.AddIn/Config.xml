<ESRI.Configuration xmlns="http://schemas.esri.com/Desktop/AddIns"
                    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <Name>arcmap-mcp</Name>
  <AddInID>{51f4ce63-6bcf-49b2-ae3a-ba2c79ea3e1a}</AddInID>
  <Description>Levanta/para el puente MCP dentro de ArcMap (socket 127.0.0.1:27179). Permite conducir la sesion viva de ArcMap desde un agente IA (Claude, etc.). Autor: Pedro Alcoba Gomez (pedralcg.dev).</Description>
  <Version>2.4.3</Version>
  <Author>Pedro Alcoba Gomez — pedralcg.dev · pedro@pedralcg.dev · GitHub @pedralcg</Author>
  <Company>pedralcg.dev</Company>
  <Date>2026-06-11</Date>
  <Targets>
    <Target name="Desktop" version="10.5" />
  </Targets>

  <AddIn language="CLR4.5" library="ArcmapMcp.AddIn.dll" namespace="ArcmapMcp.AddIn">
    <ArcMap>

      <Extensions>
        <Extension id="pedralcg_arcmap_mcp_Extension"
                   class="McpExtension"
                   productName="arcmap-mcp"
                   showInExtensionDialog="false"
                   autoLoad="true" />
      </Extensions>

      <Commands>
        <Button id="pedralcg_arcmap_mcp_Start"
                class="StartMcpButton"
                message="Arranca el puente MCP (socket 127.0.0.1:27179)."
                caption="Iniciar MCP"
                tip="Levantar el puente MCP (socket 127.0.0.1:27179)"
                image="Images/start.png"
                category="arcmap-mcp"
                onDemand="false" />
        <Button id="pedralcg_arcmap_mcp_Stop"
                class="StopMcpButton"
                message="Detiene el puente MCP."
                caption="Detener MCP"
                tip="Detener el puente MCP"
                image="Images/stop.png"
                category="arcmap-mcp"
                onDemand="false" />
        <Button id="pedralcg_arcmap_mcp_Status"
                class="StatusMcpButton"
                message="Muestra el estado del puente MCP."
                caption="Estado MCP"
                tip="Ver estado del puente (ACTIVO / PARADO) y host:puerto"
                image="Images/status.png"
                category="arcmap-mcp"
                onDemand="false" />
        <Button id="pedralcg_arcmap_mcp_About"
                class="AboutMcpButton"
                message="Informacion del autor de arcmap-mcp."
                caption="Acerca de"
                tip="Ficha del autor: Pedro Alcoba Gomez - pedralcg.dev"
                image="Images/about.png"
                category="arcmap-mcp"
                onDemand="false" />
      </Commands>

      <Toolbars>
        <Toolbar id="pedralcg_arcmap_mcp_Toolbar" caption="arcmap-mcp" showInitially="true">
          <Items>
            <Button refID="pedralcg_arcmap_mcp_Start" separator="false" />
            <Button refID="pedralcg_arcmap_mcp_Stop" separator="false" />
            <Button refID="pedralcg_arcmap_mcp_Status" separator="false" />
            <Button refID="pedralcg_arcmap_mcp_About" separator="true" />
          </Items>
        </Toolbar>
      </Toolbars>

    </ArcMap>
  </AddIn>
</ESRI.Configuration>
